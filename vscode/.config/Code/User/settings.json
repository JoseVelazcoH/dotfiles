{
    "workbench.activityBar.location": "hidden",
    "workbench.editor.showTabs": "single",
    "workbench.statusBar.visible": false,
    "workbench.startupEditor": "none",
    "workbench.tips.enabled": false,
    "editor.minimap.enabled": false,
    "breadcrumbs.enabled": false,
    "workbench.sideBar.location": "right",
    "workbench.iconTheme": "material-icon-theme",
    "material-icon-theme.hidesExplorerArrows": true,
    "workbench.tree.enableStickyScroll": false,
    "workbench.tree.renderIndentGuides": "none",
    "workbench.tree.indent": 8,
    "explorer.compactFolders": false,
    "explorer.confirmDragAndDrop": false,
    "explorer.confirmDelete": false,
    "git.decorations.enabled": true,
    "window.zoomLevel": 2.5,
    "window.customTitleBarVisibility": "never",
    "window.titleBarStyle": "native",
    "custom-ui-style.electron": {
        "titleBarStyle": "hiddenInset",
        "trafficLightPosition": {
            "x": 20,
            "y": 16
        }
    },
  "custom-ui-style.stylesheet": {
    ".quick-input-widget .monaco-inputbox": "padding: 10px !important; border-radius: 5px !important; font-size: 14px !important; border: 1px solid #ffaffc !important; background: rgba(26, 26, 26, 0.95) !important; color: #ffffff !important;",
    ".quick-input-widget .monaco-inputbox input": "color: #ffffff !important; background: transparent !important;",
    ".quick-input-widget .monaco-inputbox .monaco-inputbox-idle": "border: 1.5px solid #ffaffc !important;",
    ".quick-input-widget .quick-input-list-entry .codicon[class*=codicon-]": "font-size: 15px;",
    ".quick-input-widget .monaco-list-row": "padding: 5px !important; height: auto !important;",
    ".quick-input-widget .quick-input-list-entry": "position: relative; padding: 0px 5px 0px 15px;",
    ".quick-input-filter .monaco-inputbox": "background-color: #151516 !important; border-radius: 12px !important; border: none !important; font-family: 'Liberation Mono' !important; font-size: 16px !important; margin-bottom: 16px !important; padding: 8px !important;",
    ".monaco-inputbox input::placeholder": "color: #ffaffc !important;",
    ".monaco-grid-view": "transition: filter 0.2s !important;",
    ".monaco-workbench:has(> .quick-input-widget):not(:has(> .quick-input-widget[style*='display: none'])) .monaco-grid-view": "filter: brightness(80%) !important;",
    ".notification-toast": "box-shadow: none !important;",
    ".quick-input-widget.show-file-icons": "box-shadow: none !important;",
    ".quick-input-widget": "top: 25vh !important; box-shadow: 0 5px 10px rgba(0,0,0,0), 0 0 0 100vw rgba(0,0,0,0.15) !important;",
    ".quick-input-list .scrollbar": "display: none;",
    ".monaco-action-bar.quick-input-inline-action-bar": "display: none;",
    ".monaco-editor .scroll-decoration": "display: none;",
    ".monaco-editor .cursors-layer .cursor": "background-image: linear-gradient(135deg, #ffaffc 10%, #DA70D6 10%);",
    ".title-actions": "display: none !important;",
    ".title.show-file-icons .label-container .monaco-icon-label.file-icon": "justify-content: center; padding: 0 !important;",
    ".monaco-workbench .part.editor > .content .editor-group-container > .title > .label-container": "padding-left: 50px;",
    ".monaco-workbench .part.editor>.content .editor-group-container>.title .title-label .label-name, .monaco-workbench .part.editor>.content .editor-group-container>.title .tabs-container>.tab .tab-label .label-name": {
      "color": "#b180fff0",
      "fontSize": "20pt"
    },
    ".sidebar": "border: none !important;",
    ".sidebar .title-label": "padding: 0 !important;",
    ".editor-widget.find-widget": "box-shadow: none; border-radius: 4px;"
  },
    "custom-ui-style.font.sansSerif": "Dank Mono",
    "editor.multiCursorModifier": "alt",
    "editor.cursorBlinking": "solid",
    "editor.cursorStyle": "block",
    "editor.fontFamily": "Dank Mono",
    "editor.fontSize": 12,
    "editor.fontLigatures": true,
    "editor.lineHeight": 2.5,
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "scope": "comment",
                "settings": {
                    "fontStyle": "italic"
                }
            }
        ]
    },
    "editor.stickyScroll.enabled": false,
    "editor.colorDecorators": true,
    "editor.links": false,
    "editor.matchBrackets": "never",
    "editor.parameterHints.enabled": false,
    "editor.lightbulb.enabled": "off",
    "editor.hover.enabled": true,
    "files.trimTrailingWhitespace": true,
    "files.insertFinalNewline": true,
    "editor.lineNumbers": "on",
    "editor.tabSize": 4,
    "editor.detectIndentation": false,
    "editor.showFoldingControls": "never",
    "editor.guides.indentation": false,
    "editor.renderWhitespace": "none",
    "editor.renderLineHighlight": "none",
    "editor.occurrencesHighlight": "off",
    "editor.selectionHighlight": false,
    "editor.scrollbar.horizontal": "hidden",
    "editor.scrollbar.vertical": "hidden",
    "editor.overviewRulerBorder": false,
    "editor.hideCursorInOverviewRuler": true,
    "editor.suggestOnTriggerCharacters": true,
    "editor.tabCompletion": "on",
    "editor.snippetSuggestions": "top",
    "emmet.triggerExpansionOnTab": true,
    "update.mode": "none",
    "extensions.ignoreRecommendations": true,
    "workbench.colorTheme": "One Dark Pro Night Flat",
    "window.menuBarVisibility": "toggle",
    "workbench.editor.highlightModifiedTabs": true,
    "files.autoSave": "off",
    "explorer.decorations.colors": true,
    "explorer.decorations.badges": true,
    "workbench.editor.decorations.badges": true,
    "files.hotExit": "off",
    "files.enableTrash": false,
"workbench.colorCustomizations": {
    // "editorCursor.background": "#262626",
    // "editor.background": "#000c00",
    // "panel.border": "#262626",
    // "sideBar.border": "#262626",
    // "panelTitle.activeBorder": "#262626",
    "panelTitle.activeForeground": "#ffffff",
    "panelTitle.inactiveForeground": "#00adcc",
    // "panel.background": "#010c01",
    // "sideBar.background": "#000c00",
     "list.inactiveSelectionForeground": "#16e4ff",
    "list.activeSelectionForeground": "#16e4ff",
    "list.focusForeground": "#54ff16",
},
    "python.createEnvironment.trigger": "off",
   "python.analysis.diagnosticSeverityOverrides": {
        "reportUndefinedVariable": "none",
        "reportMissingImports": "none",
        "reportMissingModuleSource": "none"
    },
    "files.exclude": {
        "**/__pycache__": true
    }
}
